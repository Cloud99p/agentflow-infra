# AgentFlow Infra - Environment Configuration

# Bitget API (Required for Trading)
BITGET_API_KEY=your_bitget_api_key_here
BITGET_API_SECRET=your_bitget_secret_here
BITGET_PASSPHRASE=your_bitget_passphrase_here

# Bitget Agent Hub (Optional - for agent orchestration)
BITGET_AGENT_HUB_URL=https://agent-api.bitget.com
BITGET_AGENT_ID=your_agent_id_here

# US Stocks API (Optional - for tokenized stocks data)
BITGET_STOCKS_API_URL=https://stock-api.bitget.com
BITGET_STOCKS_API_KEY=your_stocks_api_key_here

# AI Configuration (DeepSeek)
AI_API_KEY=sk-your-deepseek-api-key-here
AI_MODEL=deepseek-chat
AI_TIMEOUT_MS=30000

# Execution Configuration
MIN_GAS_PRICE=1000
MAX_GAS_PRICE=50000
MAX_SLIPPAGE_PERCENT=2.0
TRADE_TIMEOUT_MS=60000

# Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_HOST=localhost

# Logging
DEBUG=true
LOG_LEVEL=info
LOG_FILE=agentflow.log

# Audit Trail
AUDIT_ENABLED=true
AUDIT_FILE=audit_log.json
